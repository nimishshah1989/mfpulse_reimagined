# MF Pulse Engine — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=MF Pulse Engine
APP_VERSION=0.1.0
APP_ENV=development
APP_PORT=8001
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://fie:changeme@localhost:5432/mf_pulse

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://mfpulse.jslwealth.in

# ── Admin Auth ───────────────────────────────────────────────────────────────
# Required in production (APP_ENV != development). Checked via X-Admin-Key header.
ADMIN_API_KEY=

# ── Morningstar API Center ───────────────────────────────────────────────────
MORNINGSTAR_API_URL=https://api.morningstar.com/v2/service/mf
MORNINGSTAR_USERNAME=
MORNINGSTAR_PASSWORD=
MORNINGSTAR_ACCESS_CODE=

# Universe and API base (override defaults if needed)
MORNINGSTAR_UNIVERSE_CODE=your-universe-code
MORNINGSTAR_API_BASE=https://api.morningstar.com/v2/service/mf

# API hashes — one per Morningstar Feed Builder API
MORNINGSTAR_HASH_IDENTIFIER=your-identifier-api-hash
MORNINGSTAR_HASH_ADDITIONAL=your-additional-api-hash
MORNINGSTAR_HASH_CATEGORY=your-category-api-hash
MORNINGSTAR_HASH_NAV=your-nav-api-hash
MORNINGSTAR_HASH_RETURNS=your-returns-api-hash
MORNINGSTAR_HASH_RISK=your-risk-stats-api-hash
MORNINGSTAR_HASH_RANKS=your-rank-data-api-hash
MORNINGSTAR_HASH_CATRETURNS=your-category-returns-api-hash
MORNINGSTAR_HASH_HOLDINGS=your-portfolio-data-api-hash
MORNINGSTAR_HASH_PORTFOLIO_SUMMARY=your-portfolio-summary-api-hash
MORNINGSTAR_HASH_HOLDINGS_DETAIL=your-holdings-detail-api-hash
MORNINGSTAR_HASH_EXTENDED_RISK=your-extended-risk-api-hash

# ── MarketPulse Bridge ───────────────────────────────────────────────────────
MARKETPULSE_BASE_URL=http://localhost:8000
MARKETPULSE_TIMEOUT_SECONDS=30

# ── Data Feeds ───────────────────────────────────────────────────────────────
FEED_CSV_DIR=/app/data_feeds

# ── Anthropic (Claude AI) ────────────────────────────────────────────────────
# LLM API keys (Groq is primary/free, Claude is fallback)
GROQ_API_KEY=your-groq-api-key-from-console.groq.com
ANTHROPIC_API_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
